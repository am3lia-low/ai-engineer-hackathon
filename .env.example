# Required: OpenAI key powers screen description, summaries, replies, and Whisper STT.
OPENAI_API_KEY=your_openai_key_here

# Optional: ElevenLabs key for high-quality TTS. Without it the cat falls
# back to the system speech synthesizer (browser TTS).
ELEVENLABS_API_KEY=your_elevenlabs_key_here_optional

# Optional model overrides. Defaults to gpt-4o-mini for both text and vision.
# OPENAI_TEXT_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini
